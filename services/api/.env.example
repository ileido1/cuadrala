## API Cuádrala — variables de entorno (EJEMPLO)
## Copia este archivo como `.env` y ajusta valores.

# development | test | production
NODE_ENV=development

# Puerto HTTP
PORT=4000

# PostgreSQL (obligatoria)
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/cuadrala?schema=public

# Pool PostgreSQL (pg) — útil para HA y evitar saturación
PG_POOL_MAX=10
PG_POOL_IDLE_TIMEOUT_MS=30000
PG_POOL_CONNECTION_TIMEOUT_MS=10000

# Secretos JWT (en producción define valores distintos, >= 32 chars)
JWT_ACCESS_SECRET=dev-only-access-secret-min-32-chars-long!!
JWT_REFRESH_SECRET=dev-only-refresh-secret-min-32-chars-long!!

# Base dedicada para tests de integración (opcional)
TEST_DATABASE_URL=postgresql://USER:carlos@localhost:5432/cuadrala?schema=public

