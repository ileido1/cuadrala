// Esquema core Fase 3 — Cuadrala API (SDD mínimo viable)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---

enum MatchType {
  AMERICANO
  REGULAR
}

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  FINISHED
  CANCELLED
}

enum TournamentStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  WITHDRAWN
}

enum SubscriptionType {
  FREE
  PRO
}

enum FeeScope {
  MATCH
  RESERVATION
}

enum FeeType {
  FIXED
  PERCENTAGE
}

enum TransactionStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum PaymentMethod {
  MANUAL
}

enum CurrencyCode {
  BS
  USD
  EUR
}

/// Tipo de asiento en libro mayor de reserva (Fase 2 MCP).
enum LedgerEntryType {
  OBLIGATION
  PAYMENT
  FEE
  ADJUSTMENT
  REVERSAL
}

enum LedgerDirection {
  DEBIT
  CREDIT
}

/// Medios de pago configurables por venue (efectivo, transferencia, pago móvil, POS, etc.)
model VenuePaymentMethod {
  id        String   @id @default(uuid())
  venueId   String
  venue     Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  type      String   // 'CASH' | 'BANK_TRANSFER' | 'PAGO_MOVIL' | 'POS' | 'OTHER'
  name      String
  config    Json?    // { accountNumber?, bank?, phoneNumber?, idType?, idNumber?, reference? }
  /// Moneda en la que liquida este medio (Modelo C — capa liquidación).
  settlementCurrency CurrencyCode
  isActive  Boolean  @default(true)
  position  Int      @default(0)

  confirmedTransactions Transaction[]

  @@index([venueId])
  @@index([venueId, isActive])
}

/// Tasas de cambio por país, moneda y fecha efectiva (histórico diario).
model ExchangeRate {
  id            String   @id @default(uuid())
  countryCode   String
  currency      String
  rateToBs      Decimal  @db.Decimal(14, 4)
  /// Día calendario (TZ sede) al que aplica la tasa.
  effectiveDate DateTime @db.Date
  source        String?
  updatedAt     DateTime @updatedAt

  currencyConversions CurrencyConversionRecord[]

  @@unique([countryCode, currency, effectiveDate])
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum VenueStaffRole {
  OWNER
  STAFF
}

enum MatchResultDraftStatus {
  DRAFT
  REJECTED
  FINALIZED
}

enum MatchResultConfirmationStatus {
  CONFIRMED
  REJECTED
}

enum DominantHand {
  RIGHT
  LEFT
  AMBIDEXTROUS
}

enum SidePreference {
  RIGHT
  LEFT
  ANY
}

/// Esquema de clasificación de categoría por deporte.
enum CategoryScheme {
  RACKET_ORDINAL
  TEAM_SKILL
}

/// Banda de nivel para agrupar categorías en onboarding.
enum SkillBand {
  BASIC
  INTERMEDIATE
  ADVANCED
}

enum NotificationEventType {
  MATCH_SLOT_OPENED
  MATCH_CANCELLED
  CHAT_MESSAGE
  PAYMENT_PENDING
  MATCH_PLAYER_JOINED
  PAYMENT_CONFIRMED
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum DevicePushTokenProvider {
  FCM
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum AvailabilitySlot {
  MORNING
  AFTERNOON
  EVENING
}

enum CourtStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum ReservationType {
  DIRECT
  BLOCKED
  MATCH
}

enum Visibility {
  PUBLISHED
  DRAFT
  PRIVATE
}

enum ReservationStatus {
  CONFIRMED
  CANCELLED
}

enum SportType {
  PADEL
  TENNIS
}

// --- Catálogo multi-deporte (E0) ---

/// Deporte configurable (PADEL, etc.); el producto puede mostrar solo pádel en MVP.
model Sport {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())

  formatPresets       TournamentFormatPreset[]
  matches             Match[]
  tournaments         Tournament[]
  playerSportProfiles PlayerSportProfile[]
  reservations        Reservation[]
  categories          Category[]
  userSportCategories UserSportCategory[]
}

/// Preset de formato de torneo por deporte (Americano, Round Robin, etc.).
model TournamentFormatPreset {
  id                String                   @id @default(uuid())
  sportId           String
  sport             Sport                    @relation(fields: [sportId], references: [id], onDelete: Cascade)
  code              String
  /// Versión del preset (por sport+code). Incremental, inicia en 1.
  version           Int                      @default(1)
  name              String
  /// Versión del esquema de `defaultParameters` / `formatParameters` en torneos existentes.
  schemaVersion     Int                      @default(1)
  defaultParameters Json
  isActive          Boolean                  @default(true)
  /// Desde cuándo esta versión es elegible como "vigente" (si isActive=true).
  effectiveFrom     DateTime                 @default(now())
  /// Versión previa del mismo preset (misma family sport+code) que esta versión reemplaza.
  supersedesId      String?
  supersedes        TournamentFormatPreset?  @relation("TournamentFormatPresetSupersedes", fields: [supersedesId], references: [id], onDelete: SetNull)
  supersededBy      TournamentFormatPreset[] @relation("TournamentFormatPresetSupersedes")
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  tournaments Tournament[]
  matches     Match[]

  @@unique([sportId, code, version])
  @@index([sportId, code, isActive, effectiveFrom, version])
}

// --- Modelos ---

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  name             String
  /// Hash bcrypt; nulo para usuarios creados antes de E1 o por seed sin contraseña.
  passwordHash     String?
  subscriptionType SubscriptionType @default(FREE)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  tournamentRegistrations     TournamentRegistration[]
  matchParticipants           MatchParticipant[]
  rankingEntries              RankingEntry[]
  matchResultScores           MatchResultScore[]
  matchResultDraftsCreated    MatchResultDraft[]         @relation("UserMatchResultDraftsCreated")
  matchResultConfirmations    MatchResultConfirmation[]
  ratings                     UserRating[]
  ratingHistory               UserRatingHistory[]
  transactions                Transaction[]
  notificationSubscriptions   NotificationSubscription[]
  notificationDeliveries      NotificationDelivery[]
  devicePushTokens            DevicePushToken[]
  refreshTokens               RefreshToken[]
  uploadedTransactionReceipts TransactionReceipt[]       @relation("UserUploadedTransactionReceipts")
  chatMessages                ChatMessage[]
  venueStaffRoles             VenueStaff[]
  ownedVenue                  Venue?

  categories       UserCategory[]
  sportCategories  UserSportCategory[]
  playerProfile    PlayerProfile?
  availability     UserAvailability[]
  location         UserLocation?
  organizedMatches Match[]            @relation("MatchOrganizer")
}

model RefreshToken {
  id                String         @id @default(uuid())
  userId            String
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// JWT ID (jti). Single-use y único globalmente.
  jti               String         @unique
  /// Agrupa rotaciones de un mismo "login" (sesión).
  sessionId         String
  /// Metadata opcional (observabilidad / auditoría).
  userAgent         String?
  deviceId          String?
  ip                String?
  createdAt         DateTime       @default(now())
  expiresAt         DateTime
  revokedAt         DateTime?
  rotatedAt         DateTime?
  replacedByTokenId String?
  replacedByToken   RefreshToken?  @relation("RefreshTokenReplacedBy", fields: [replacedByTokenId], references: [id], onDelete: SetNull)
  replaces          RefreshToken[] @relation("RefreshTokenReplacedBy")

  @@index([userId])
  @@index([sessionId])
  @@index([expiresAt])
}

model PlayerProfile {
  id                    String         @id @default(uuid())
  userId                String         @unique
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  dominantHand          DominantHand   @default(RIGHT)
  sidePreference        SidePreference @default(ANY)
  birthYear             Int?
  /// Fecha de nacimiento (YYYY-MM-DD). Se usa para segmentación por categorías.
  birthDate             DateTime?
  /// E.164 (+5491145454545). Validado por backend con regex laxa.
  phone                 String?
  /// Número de documento (DNI, CI, etc.). Único por usuario.
  documentNumber        String?                 @unique
  avatarUrl             String?
  city                  String?
  /// Marca el momento en que el usuario completó todos los pasos requeridos del onboarding.
  onboardingCompletedAt DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  sportProfiles PlayerSportProfile[]

  @@index([userId])
}

/// Perfil técnico por deporte: nivel, lado preferido, etc. Reemplaza al `sidePreference` global de PlayerProfile (que se mantiene como default heredado).
model PlayerSportProfile {
  id              String         @id @default(uuid())
  playerProfileId String
  playerProfile   PlayerProfile  @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)
  sportId         String
  sport           Sport          @relation(fields: [sportId], references: [id], onDelete: Cascade)
  /// Nivel autodeclarado (escala genérica 1.0 a 7.0). Para pádel/tenis 1.0=principiante, 7.0=elite.
  skillLevel      Decimal        @db.Decimal(3, 1)
  sidePreference  SidePreference @default(ANY)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([playerProfileId, sportId])
  @@index([sportId])
}

/// Disponibilidad horaria del usuario por día y franja (multi-fila).
model UserAvailability {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayOfWeek DayOfWeek
  slot      AvailabilitySlot
  createdAt DateTime         @default(now())

  @@unique([userId, dayOfWeek, slot])
  @@index([userId])
}

/// Ubicación de referencia y radio de búsqueda del usuario.
model UserLocation {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Etiqueta libre (ej. "Caracas — La Castellana").
  label     String?
  latitude  Decimal  @db.Decimal(10, 7)
  longitude Decimal  @db.Decimal(10, 7)
  /// Radio en km (1–100).
  radiusKm  Int      @default(10)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

/// Categoría actual del usuario (MVP). Permite validar unión a partidas por categoría.
model UserCategory {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, categoryId])
  @@index([categoryId])
}

/// Categoría de juego por deporte (una activa por userId + sportId).
model UserSportCategory {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sportId    String
  sport      Sport    @relation(fields: [sportId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, sportId])
  @@index([categoryId])
}

model Category {
  id        String         @id @default(uuid())
  sportId   String
  sport     Sport          @relation(fields: [sportId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  scheme    CategoryScheme
  skillBand SkillBand?
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())

  matches                   Match[]
  rankingEntries            RankingEntry[]
  tournaments               Tournament[]
  userCategories            UserCategory[]
  userSportCategories       UserSportCategory[]
  ratings                   UserRating[]
  ratingHistory             UserRatingHistory[]
  notificationSubscriptions NotificationSubscription[]
  notificationEvents        NotificationEvent[]
  reservations              Reservation[]

  @@unique([sportId, slug])
  @@index([sportId, scheme])
}

model UserRating {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  rating     Float    @default(1500)
  updatedAt  DateTime @updatedAt

  @@unique([categoryId, userId])
  @@index([categoryId, rating])
  @@index([userId])
}

model UserRatingHistory {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId     String
  category       Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  matchId        String
  resultId       String
  previousRating Float
  newRating      Float
  kFactor        Float
  createdAt      DateTime @default(now())

  @@unique([resultId, userId])
  @@index([categoryId, createdAt])
  @@index([userId, createdAt])
}

model Venue {
  id                String    @id @default(uuid())
  name              String
  address           String?
  latitude          Float?
  longitude         Float?
  /// placeId del proveedor (Mapbox/Google). Único cuando existe.
  placeId           String?   @unique
  /// Dirección normalizada (texto completo) del proveedor.
  formattedAddress  String?
  addressCountry    String?
  addressState      String?
  addressCity       String?
  addressLine1      String?
  addressPostalCode String?
  geocodedAt        DateTime?
  /// Instrucciones de pago para transferencias al venue.
  paymentHolder     String?
  paymentBank       String?
  paymentCvu        String?
  paymentAlias      String?
  paymentNotes      String?
  /// Moneda de visualización del venue (legacy; preferir pricingCurrency).
  displayCurrency   String       @default("BS")
  /// País para tasas de cambio (ISO 3166-1 alpha-2).
  countryCode       String       @default("VE")
  /// Moneda de obligación / pricing (Modelo C — capa comercial).
  pricingCurrency   CurrencyCode @default(BS)
  /// Usuario propietario de la sede (nullable para compatibilidad hacia atrás).
  ownerUserId       String?   @unique
  owner             User?     @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  phone             String?
  email             String?
  description       String?
  openingHours      Json?     // { monday: { open: "08:00", close: "23:00" }, ... }
  createdAt         DateTime  @default(now())

  courts      Court[]
  staff       VenueStaff[]
  reservations         Reservation[]
  venuePaymentMethods  VenuePaymentMethod[]
  venueFeeRules        VenueFeeRule[]
  monetizationSettings VenueMonetizationSettings?

  @@index([latitude, longitude])
}

/// Configuración monetaria por sede (timezone, tolerancia sobrepago).
model VenueMonetizationSettings {
  venueId                   String   @id
  timezone                  String   @default("America/Caracas")
  allowOverpayment          Boolean  @default(false)
  overpaymentToleranceMinor BigInt?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  venue                     Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
}

model VenueStaff {
  id        String         @id @default(uuid())
  venueId   String
  venue     Venue          @relation(fields: [venueId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      VenueStaffRole @default(STAFF)
  createdAt DateTime       @default(now())

  @@unique([venueId, userId])
  @@index([userId])
}

model Court {
  id              String      @id @default(uuid())
  venueId         String
  venue           Venue       @relation(fields: [venueId], references: [id], onDelete: Cascade)
  name            String
  sportType       SportType   @default(PADEL)
  indoor          Boolean     @default(false)
  lighting        Boolean     @default(false)
  surfaceType     String?
  status          CourtStatus @default(ACTIVE)
  pricePerHourCents Int?      // Precio por hora en centavos
  capacity        String?     // ej. "4v4"
  durationMinutes Int         @default(60)
  createdAt       DateTime    @default(now())

  matches     Match[]
  reservations Reservation[]
  pricingTiers CourtPricingTier[]
}

// --- Court Pricing Tiers ---

model CourtPricingTier {
  id                String   @id @default(uuid())
  courtId           String
  court             Court    @relation(fields: [courtId], references: [id], onDelete: Cascade)
  label             String   // ej. "Mañana", "Tarde", "Noche"
  startTime         String   // "08:00" (24h)
  endTime           String   // "12:00" (24h)
  pricePerHourCents Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([courtId])
}

model Tournament {
  id                  String                 @id @default(uuid())
  name                String
  categoryId          String
  category            Category               @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  sportId             String
  sport               Sport                  @relation(fields: [sportId], references: [id], onDelete: Cascade)
  formatPresetId      String
  formatPreset        TournamentFormatPreset @relation(fields: [formatPresetId], references: [id], onDelete: Restrict)
  /// Parámetros concretos del torneo (pueden sobrescribir defaults del preset).
  formatParameters    Json?
  /// Copia de schemaVersion del preset al crear el torneo (inmutabilidad lógica).
  presetSchemaVersion Int                    @default(1)
  status              TournamentStatus       @default(DRAFT)
  startsAt            DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  registrations     TournamentRegistration[]
  matches           Match[]
  americanoSchedule TournamentAmericanoSchedule?
  schedule          TournamentSchedule?
  chatThread        ChatThread?

  @@index([sportId])
  @@index([formatPresetId])
}

/// Schedule genérico por torneo (MVP: reutiliza payload JSON).
model TournamentSchedule {
  id           String     @id @default(uuid())
  tournamentId String     @unique
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  /// Código del formato (ej. AMERICANO, ROUND_ROBIN).
  formatCode  String
  /// Key determinista (idempotencia).
  scheduleKey String
  /// Payload JSON del schedule (estructura depende del formato).
  payload     Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([formatCode])
}

/// Schedule generado para formato AMERICANO a nivel torneo (idempotente por tournamentId).
model TournamentAmericanoSchedule {
  id           String     @id @default(uuid())
  tournamentId String     @unique
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  /// Key determinista derivada de inputs (participantes, parámetros, etc.). Evita duplicar schedules.
  scheduleKey  String
  /// JSON con rondas/partidos (estructura definida por dominio; estable para API).
  schedule     Json
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model TournamentRegistration {
  id           String             @id @default(uuid())
  tournamentId String
  tournament   Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status       RegistrationStatus @default(PENDING)
  createdAt    DateTime           @default(now())

  @@unique([tournamentId, userId])
}

model Match {
  id                  String                  @id @default(uuid())
  categoryId          String
  category            Category                @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  sportId             String
  sport               Sport                   @relation(fields: [sportId], references: [id], onDelete: Cascade)
  organizerUserId     String
  organizer           User                    @relation("MatchOrganizer", fields: [organizerUserId], references: [id], onDelete: Restrict)
  formatPresetId      String?
  formatPreset        TournamentFormatPreset? @relation(fields: [formatPresetId], references: [id], onDelete: SetNull)
  formatParameters    Json?
  courtId             String?
  court               Court?                  @relation(fields: [courtId], references: [id], onDelete: SetNull)
  tournamentId        String?
  tournament          Tournament?             @relation(fields: [tournamentId], references: [id], onDelete: SetNull)
  /// Compatibilidad: tipo legacy; el formato parametrizable vive en preset + parameters.
  type                MatchType
  status              MatchStatus             @default(SCHEDULED)
  scheduledAt         DateTime?
  /// Precio por jugador (cents). 0 = gratis/no definido en MVP.
  pricePerPlayerCents Int                     @default(0)
  /// Cupo máximo de participantes (MVP). Para Americano suele ser 4, pero se deja configurable.
  maxParticipants     Int                     @default(4)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  participants       MatchParticipant[]
  results            MatchResult[]
  resultDrafts       MatchResultDraft[]
  transactions       Transaction[]
  notificationEvents NotificationEvent[]
  chatThread         ChatThread?
  // Relación 1:1 con Reservation (companion para type=MATCH)
  reservation        Reservation? @relation("ReservationMatch")

  @@index([categoryId])
  @@index([status])
  @@index([sportId])
  @@index([scheduledAt])
  @@index([pricePerPlayerCents])
  @@index([organizerUserId])
}

model Reservation {
  id         String           @id @default(uuid())
  venueId    String
  venue      Venue            @relation(fields: [venueId], references: [id], onDelete: Cascade)
  courtId    String
  court      Court            @relation(fields: [courtId], references: [id], onDelete: Cascade)
  sportId    String
  sport      Sport            @relation(fields: [sportId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category         @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  type             ReservationType   @default(DIRECT)
  // MATCH-specific fields (nullable for DIRECT/BLOCKED)
  matchId            String?          @unique  // 1:1 link a Match (companion, no FK)
  organizerUserId     String?
  formatPresetId      String?
  formatParameters   Json?
  maxParticipants     Int             @default(4)
  pricePerPlayerCents Int             @default(0)
  visibility          Visibility?     // null for DIRECT/BLOCKED
  matchStatus         MatchStatus?    // solo cuando type=MATCH

  status           ReservationStatus @default(CONFIRMED)
  scheduledAt      DateTime
  durationMinutes  Int              @default(60)
  notes            String?
  createdByUserId  String
  /// Nombre del responsable (para reservas directas de guests o referencia).
  responsibleName  String?
  /// Teléfono del responsable (para reservas directas de guests o referencia).
  responsiblePhone String?
  /// Monto total de la reserva en centavos (legacy; dual-write con totalAmountMinor).
  totalAmountCents Int?
  /// Suma de montos confirmados en centavos (legacy; dual-write con paidAmountMinor).
  paidAmountCents  Int             @default(0)
  /// Moneda de obligación de la reserva (copia de venue.pricingCurrency al crear).
  pricingCurrency  CurrencyCode
  /// Monto total en unidades menores (centavos/céntimos según moneda).
  totalAmountMinor BigInt?
  /// Suma pagada en pricingCurrency (unidades menores).
  paidAmountMinor  BigInt          @default(0)
  /// Suma pagada acumulada en BS (reporting platform; Fase 2).
  paidAmountBsMinor BigInt?
  /// Estado de pago: UNPAID (nada), PARTIAL (algo), PAID (cubierto o más).
  paymentStatus     PaymentStatus   @default(UNPAID)

  transactions   Transaction[]
  ledgerEntries  ReservationPaymentLedger[]

  // Relación 1:1 con Match (companion table para type=MATCH)
  match       Match?     @relation("ReservationMatch", fields: [matchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([courtId, scheduledAt])
  @@index([courtId, scheduledAt])
  @@index([venueId])
  @@index([status])
  @@index([type])
  @@index([visibility])
  @@index([matchId])
}

model MatchResultDraft {
  id               String                 @id @default(uuid())
  matchId          String
  match            Match                  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  /// Incremental por match (auditoría mínima y control de repropuestas). Inicia en 1.
  version          Int
  status           MatchResultDraftStatus @default(DRAFT)
  payload          Json
  proposedByUserId String
  proposedByUser   User                   @relation("UserMatchResultDraftsCreated", fields: [proposedByUserId], references: [id], onDelete: Cascade)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  confirmations MatchResultConfirmation[]

  @@unique([matchId, version])
  @@index([matchId, version])
}

model MatchResultConfirmation {
  id        String                        @id @default(uuid())
  draftId   String
  draft     MatchResultDraft              @relation(fields: [draftId], references: [id], onDelete: Cascade)
  userId    String
  user      User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    MatchResultConfirmationStatus
  createdAt DateTime                      @default(now())

  @@unique([draftId, userId])
  @@index([userId])
}

model MatchParticipant {
  id        String   @id @default(uuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamLabel String?
  createdAt DateTime @default(now())

  @@unique([matchId, userId])
  @@index([userId])
}

model MatchResult {
  id         String   @id @default(uuid())
  matchId    String
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  payload    Json?
  recordedAt DateTime @default(now())

  scores MatchResultScore[]

  @@index([matchId])
}

model MatchResultScore {
  id       String      @id @default(uuid())
  resultId String
  result   MatchResult @relation(fields: [resultId], references: [id], onDelete: Cascade)
  userId   String
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  points   Int         @default(0)

  @@unique([resultId, userId])
  @@index([userId])
}

model RankingEntry {
  id          String   @id @default(uuid())
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  points      Int      @default(0)
  gamesPlayed Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([categoryId, userId])
  @@index([categoryId, points])
}

/// Regla de comisión de servicio por ámbito (MVP: solo MATCH).
model FeeRule {
  id        String   @id @default(uuid())
  scope     FeeScope
  type      FeeType
  /// Monto fijo o porcentaje según type (porcentaje: 10 = 10%).
  value     Decimal  @db.Decimal(14, 4)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scope, isActive])
}

/// Comisión de servicio por sede y ámbito (multi-moneda).
model VenueFeeRule {
  id           String       @id @default(uuid())
  venueId      String
  venue        Venue        @relation(fields: [venueId], references: [id], onDelete: Cascade)
  scope        FeeScope
  type         FeeType
  value        Decimal      @db.Decimal(14, 4)
  currencyCode CurrencyCode
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([venueId, scope, isActive])
}

/// Obligación de pago no custodial asociada a un match o reservation y usuario.
model Transaction {
  id            String            @id @default(uuid())
  matchId       String?
  match         Match?            @relation(fields: [matchId], references: [id], onDelete: Cascade)
  reservationId String?
  reservation   Reservation?      @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountBase    Decimal           @db.Decimal(14, 4)
  feeAmount     Decimal           @db.Decimal(14, 4)
  amountTotal   Decimal           @db.Decimal(14, 4)
  /// Obligación en moneda de pricing (capa comercial).
  obligationCurrency       CurrencyCode?
  obligationAmountMinor    BigInt?
  feeAmountMinor           BigInt?
  obligationTotalMinor     BigInt?
  pricingCurrency          CurrencyCode?
  /// Liquidación real según medio de pago.
  settlementCurrency       CurrencyCode?
  settlementAmountMinor    BigInt?
  appliedToObligationMinor BigInt?
  /// Equivalente en BS para reporting VE (snapshot).
  amountBsMinor              BigInt?
  needsReview                Boolean           @default(false)
  status        TransactionStatus @default(PENDING)
  paymentMethod PaymentMethod     @default(MANUAL)
  venuePaymentMethodId String?
  venuePaymentMethod   VenuePaymentMethod? @relation(fields: [venuePaymentMethodId], references: [id])
  referenceNumber      String?    // referencia/comprobante
  paymentData         Json?      // copia de config del medio en el momento de confirmar
  confirmedAt         DateTime?
  confirmedBy         String?     // userId de quien confirmó
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  receipts                 TransactionReceipt[]
  currencyConversionRecord CurrencyConversionRecord?
  ledgerEntries            ReservationPaymentLedger[]

  @@index([matchId])
  @@index([userId])
  @@index([matchId, status])
  @@index([reservationId])
  @@index([reservationId, status])
  @@index([venuePaymentMethodId])
}

/// Snapshot inmutable de conversión para auditoría / reporting VE.
model CurrencyConversionRecord {
  id              String        @id @default(uuid())
  transactionId   String        @unique
  transaction     Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  fromCurrency    CurrencyCode
  toCurrency      CurrencyCode
  fromAmountMinor BigInt
  toAmountMinor   BigInt
  rateToBs        Decimal       @db.Decimal(14, 4)
  rateDate        DateTime      @db.Date
  exchangeRateId  String?
  exchangeRate    ExchangeRate? @relation(fields: [exchangeRateId], references: [id], onDelete: SetNull)
  source          String?
  createdAt       DateTime      @default(now())
}

/// Comprobante (imagen) adjunto a una transacción.
/// Libro mayor append-only por reserva (Fase 2 MCP).
model ReservationPaymentLedger {
  id            String           @id @default(uuid())
  reservationId String
  reservation   Reservation      @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  transactionId String?
  transaction   Transaction?     @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  entryType     LedgerEntryType
  direction     LedgerDirection
  amountMinor   BigInt
  currencyCode  CurrencyCode
  amountBsMinor BigInt?
  actorUserId   String
  reason        String?
  createdAt     DateTime         @default(now())

  @@index([reservationId, createdAt])
  @@index([transactionId])
}

model TransactionReceipt {
  id             String      @id @default(uuid())
  transactionId  String
  transaction    Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  uploaderUserId String
  uploaderUser   User        @relation("UserUploadedTransactionReceipts", fields: [uploaderUserId], references: [id], onDelete: Restrict)
  mimeType       String
  sizeBytes      Int
  storageKey     String
  createdAt      DateTime    @default(now())

  @@index([transactionId, createdAt])
  @@index([uploaderUserId, createdAt])
}

model NotificationSubscription {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  nearLat      Float?
  nearLng      Float?
  radiusKm     Float?
  enabled      Boolean   @default(true)
  /// Preferencias por tipo de evento. Si falta una key, se asume habilitado.
  enabledTypes Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([enabled])
  @@index([categoryId])
  @@index([nearLat, nearLng])
}

// --- Chat (E7-01) ---

model ChatThread {
  id           String      @id @default(uuid())
  matchId      String?     @unique
  match        Match?      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  tournamentId String?     @unique
  tournament   Tournament? @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())

  messages ChatMessage[]

  @@index([createdAt])
}

model ChatMessage {
  id           String     @id @default(uuid())
  threadId     String
  thread       ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderUserId String
  sender       User       @relation(fields: [senderUserId], references: [id], onDelete: Restrict)
  text         String
  createdAt    DateTime   @default(now())

  @@index([threadId, createdAt])
  @@index([senderUserId, createdAt])
}

model NotificationEvent {
  id          String                @id @default(uuid())
  type        NotificationEventType
  matchId     String
  match       Match                 @relation(fields: [matchId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category              @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  payload     Json
  createdAt   DateTime              @default(now())
  processedAt DateTime?

  deliveries NotificationDelivery[]

  @@index([matchId])
  @@index([categoryId])
  @@index([processedAt, createdAt])
}

model NotificationDelivery {
  id            String                     @id @default(uuid())
  eventId       String
  event         NotificationEvent          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId        String
  user          User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  status        NotificationDeliveryStatus @default(PENDING)
  error         String?
  lastErrorCode String?
  attemptCount  Int                        @default(0)
  nextAttemptAt DateTime?
  lastAttemptAt DateTime?
  createdAt     DateTime                   @default(now())
  sentAt        DateTime?
  readAt        DateTime?

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@index([userId, createdAt])
  @@index([userId, readAt, createdAt])
  @@index([status])
  @@index([nextAttemptAt])
  @@index([status, nextAttemptAt])
}

model DevicePushToken {
  id        String                  @id @default(uuid())
  userId    String
  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider  DevicePushTokenProvider @default(FCM)
  token     String
  enabled   Boolean                 @default(true)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  @@unique([provider, token])
  @@index([userId, enabled])
  @@index([provider, enabled])
}
